OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://jp-api.zhexueqi.xyz/v1
MODEL=gpt-5.4-mini
APP_LANGUAGE=zh
DB_PATH=./kagent.db
WORKSPACE_ROOT=.

# Filesystem permission scopes: workspace or all
KAGENT_FS_READ_SCOPE=all
KAGENT_FS_WRITE_SCOPE=workspace
KAGENT_FS_COMMAND_SCOPE=workspace

# Extra writable / command roots, separated by ; on Windows or : on Unix.
KAGENT_ALLOWED_WRITE_ROOTS=
KAGENT_ALLOWED_COMMAND_ROOTS=
